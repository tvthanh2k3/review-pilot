# Supabase
NEXT_PUBLIC_SUPABASE_URL=       # public
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # public
SUPABASE_SERVICE_ROLE_KEY=      # server-only — never expose to the browser

# Gemini
GEMINI_API_KEY=                 # server-only — never expose to the browser

# Google Places (requires "Places API New" enabled in Google Cloud Console)
GOOGLE_PLACES_API_KEY=          # server-only — never expose to the browser
